{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "genesis",
  // Set this to today's date
  "compatibility_date": "2026-05-30",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "www.gsoulis.blog",
      "custom_domain": true
    },
    {
      "pattern": "gsoulis.blog",
      "custom_domain": true
    }
  ]
}